# DeepSeek API 配置
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your-deepseek-api-key-here
LLM_MODEL=deepseek-chat
# 可选：结构化路线抽取使用的快速模型；留空则使用主模型
LLM_FAST_MODEL=
LLM_MAX_TOKENS=16384
LLM_TEMPERATURE=0.2

# 携程问道 API Key（WorkBuddy 连接器会自动注入，独立运行时需要手动填写）
WENDAO_API_KEY=your-ctrip-api-key-here

# 高德 Web 服务 Key（可选）：用于目的地定位、POI、天气和路线距离参考
AMAP_WEB_SERVICE_KEY=

# 飞猪开放平台（可选）：配置后航班动态查询优先走飞猪（国内可达），否则回退 OpenSky
# 申请方式见 https://open.alitrip.com/ → 入驻开发者 → 创建应用 → APP 证书
FLIGGY_APP_KEY=
FLIGGY_APP_SECRET=

# 服务配置
HOST=0.0.0.0
PORT=8080

# 同时生成报告的最大任务数；超出后排队。小内存服务器建议保持 2。
GENERATION_MAX_CONCURRENCY=2
# PDF/DOCX 转换较耗 CPU 和内存，默认同一时间只处理一个。
EXPORT_MAX_CONCURRENCY=1

# 路线与日程骨架持久化缓存时间（秒），默认 2 小时
ROUTE_PLAN_CACHE_TTL=7200
